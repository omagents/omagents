{
  "agentmemory": {
    "type": "local",
    "command": "npx",
    "args": [
      "-y",
      "@agentmemory/mcp"
    ]
  },
  "codegraph": {
    "type": "local",
    "command": "npx",
    "args": [
      "-y",
      "@colbymchenry/codegraph",
      "serve",
      "--mcp"
    ]
  },
  "context7": {
    "type": "remote",
    "url": "https://mcp.context7.com/mcp"
  },
  "websearch": {
    "type": "remote",
    "url": "https://mcp.exa.ai/mcp"
  }
}
